; NOTE: Assertions have been autogenerated by utils/update_analyze_test_checks.py
; RUN: opt -passes=loop-vectorize -disable-output  < %s -vplan-print-after=printAfterInitialConstruction 2>&1 | FileCheck %s
; REQUIRES: asserts

define void @foo(ptr %ptr, i64 %n) {
; CHECK-LABEL: 'foo'
; CHECK-NEXT:  VPlan ' for UF>=1' {
; CHECK-NEXT:  Live-in [[VP0:vp<%.*>]] = VF * UF
; CHECK-NEXT:  Live-in [[VP1:vp<%.*>]] = vector-trip-count
; CHECK-NEXT:  [[VP2:vp<%.*>]] = original trip-count
; CHECK-EMPTY:
; CHECK-NEXT:  ir-bb<entry>:
; CHECK-NEXT:    EMIT [[VP2]] = EXPAND SCEV (1 smax %n)
; CHECK-NEXT:  Successor(s): scalar.ph, vector.ph
; CHECK-EMPTY:
; CHECK-NEXT:  vector.ph:
; CHECK-NEXT:  Successor(s): header
; CHECK-EMPTY:
; CHECK-NEXT:  header:
; CHECK-NEXT:    EMIT [[VP3:vp<%.*>]] = CANONICAL-INDUCTION ir<0>, [[INDEX_NEXT:vp<%.*>]]
; CHECK-NEXT:    EMIT-SCALAR ir<%iv> = phi [ ir<0>, vector.ph ], [ ir<%iv.next>, header ]
; CHECK-NEXT:    EMIT ir<%gep> = getelementptr ir<%ptr>, ir<%iv>
; CHECK-NEXT:    EMIT store ir<%iv>, ir<%gep>
; CHECK-NEXT:    EMIT ir<%iv.next> = add nsw ir<%iv>, ir<1>
; CHECK-NEXT:    EMIT ir<%exitcond> = icmp slt ir<%iv.next>, ir<%n>
; CHECK-NEXT:    EMIT [[VP4:vp<%.*>]] = not ir<%exitcond>
; CHECK-NEXT:    EMIT [[INDEX_NEXT]] = add nuw [[VP3]], [[VP0]]
; CHECK-NEXT:    EMIT branch-on-count [[INDEX_NEXT]], [[VP1]]
; CHECK-NEXT:  Successor(s): middle.block, header
; CHECK-EMPTY:
; CHECK-NEXT:  middle.block:
; CHECK-NEXT:  Successor(s): ir-bb<exit>, scalar.ph
; CHECK-EMPTY:
; CHECK-NEXT:  ir-bb<exit>:
; CHECK-NEXT:  No successors
; CHECK-EMPTY:
; CHECK-NEXT:  scalar.ph:
; CHECK-NEXT:    EMIT-SCALAR [[VP6:vp<%.*>]] = phi [ ir<%iv>, middle.block ], [ ir<0>, ir-bb<entry> ]
; CHECK-NEXT:  Successor(s): ir-bb<header>
; CHECK-EMPTY:
; CHECK-NEXT:  ir-bb<header>:
; CHECK-NEXT:    IR %iv = phi i64 [ 0, %entry ], [ %iv.next, %header ] (extra operand: [[VP6]] from scalar.ph)
; CHECK-NEXT:    IR %gep = getelementptr i64, ptr %ptr, i64 %iv
; CHECK-NEXT:    IR store i64 %iv, ptr %gep, align 4
; CHECK-NEXT:    IR %iv.next = add nsw i64 %iv, 1
; CHECK-NEXT:    IR %exitcond = icmp slt i64 %iv.next, %n
; CHECK-NEXT:  No successors
; CHECK-NEXT:  }
; CHECK-EMPTY:
;
entry:
  br label %header

header:
  %iv = phi i64 [ 0, %entry ], [ %iv.next, %header ]
  %gep = getelementptr i64, ptr %ptr, i64 %iv
  store i64 %iv, ptr %gep
  %iv.next = add nsw i64 %iv, 1
  %exitcond = icmp slt i64 %iv.next, %n
  br i1 %exitcond, label %header, label %exit

exit:
  ret void
}

define void @bar(ptr %ptr, i64 %n) {
; CHECK-LABEL: 'bar'
; CHECK-NEXT:  VPlan ' for UF>=1' {
; CHECK-NEXT:  Live-in [[VP0:vp<%.*>]] = VF * UF
; CHECK-NEXT:  Live-in [[VP1:vp<%.*>]] = vector-trip-count
; CHECK-NEXT:  [[VP2:vp<%.*>]] = original trip-count
; CHECK-EMPTY:
; CHECK-NEXT:  ir-bb<entry>:
; CHECK-NEXT:    EMIT [[VP2]] = EXPAND SCEV (1 smax %n)
; CHECK-NEXT:  Successor(s): scalar.ph, vector.ph
; CHECK-EMPTY:
; CHECK-NEXT:  vector.ph:
; CHECK-NEXT:  Successor(s): header
; CHECK-EMPTY:
; CHECK-NEXT:  header:
; CHECK-NEXT:    EMIT [[VP3:vp<%.*>]] = CANONICAL-INDUCTION ir<0>, [[INDEX_NEXT:vp<%.*>]]
; CHECK-NEXT:    EMIT-SCALAR ir<%iv> = phi [ ir<0>, vector.ph ], [ ir<%iv.next>, latch ]
; CHECK-NEXT:    EMIT ir<%gep> = getelementptr ir<%ptr>, ir<%iv>
; CHECK-NEXT:    EMIT ir<%c> = icmp sle ir<%iv>, ir<42>
; CHECK-NEXT:    EMIT branch-on-cond ir<%c>
; CHECK-NEXT:  Successor(s): if, latch
; CHECK-EMPTY:
; CHECK-NEXT:  if:
; CHECK-NEXT:    EMIT store ir<%iv>, ir<%gep>
; CHECK-NEXT:  Successor(s): latch
; CHECK-EMPTY:
; CHECK-NEXT:  latch:
; CHECK-NEXT:    EMIT ir<%iv.next> = add nsw ir<%iv>, ir<1>
; CHECK-NEXT:    EMIT ir<%exitcond> = icmp slt ir<%iv.next>, ir<%n>
; CHECK-NEXT:    EMIT [[VP4:vp<%.*>]] = not ir<%exitcond>
; CHECK-NEXT:    EMIT [[INDEX_NEXT]] = add nuw [[VP3]], [[VP0]]
; CHECK-NEXT:    EMIT branch-on-count [[INDEX_NEXT]], [[VP1]]
; CHECK-NEXT:  Successor(s): middle.block, header
; CHECK-EMPTY:
; CHECK-NEXT:  middle.block:
; CHECK-NEXT:  Successor(s): ir-bb<exit>, scalar.ph
; CHECK-EMPTY:
; CHECK-NEXT:  ir-bb<exit>:
; CHECK-NEXT:  No successors
; CHECK-EMPTY:
; CHECK-NEXT:  scalar.ph:
; CHECK-NEXT:    EMIT-SCALAR [[VP6:vp<%.*>]] = phi [ ir<%iv>, middle.block ], [ ir<0>, ir-bb<entry> ]
; CHECK-NEXT:  Successor(s): ir-bb<header>
; CHECK-EMPTY:
; CHECK-NEXT:  ir-bb<header>:
; CHECK-NEXT:    IR %iv = phi i64 [ 0, %entry ], [ %iv.next, %latch ] (extra operand: [[VP6]] from scalar.ph)
; CHECK-NEXT:    IR %gep = getelementptr i64, ptr %ptr, i64 %iv
; CHECK-NEXT:    IR %c = icmp sle i64 %iv, 42
; CHECK-NEXT:  No successors
; CHECK-NEXT:  }
; CHECK-EMPTY:
;
entry:
  br label %header

header:
  %iv = phi i64 [ 0, %entry ], [ %iv.next, %latch ]
  %gep = getelementptr i64, ptr %ptr, i64 %iv
  %c = icmp sle i64 %iv, 42
  br i1 %c, label %if, label %latch

if:
  store i64 %iv, ptr %gep
  br label %latch

latch:
  %iv.next = add nsw i64 %iv, 1
  %exitcond = icmp slt i64 %iv.next, %n
  br i1 %exitcond, label %header, label %exit

exit:
  ret void
}
