; CHECK-NEXT:            %3 = load i32, ptr %gep.iv.4, align 4 ->
; CHECK-NEXT:            store i32 %add3, ptr %gep.iv, align 4
; CHECK-EMPTY:
; CHECK-NEXT:        BackwardVectorizableButPreventsForwarding:
; CHECK-NEXT:            %1 = load i32, ptr %gep.iv.sub.3, align 4 ->
; CHECK-NEXT:            store i32 %add3, ptr %gep.iv, align 4
